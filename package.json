{
  "name": "home-dashboard",
  "type": "module",
  "scripts": {
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "typecheck": "bun tsc --noEmit",
    "css": "tailwindcss -i src/style.css -o dist/style.css",
    "dev": "concurrently \"bun dev:server\" \"bun dev:client\" \"bun dev:css\"",
    "dev:server": "bun run --hot src/index.tsx",
    "dev:client": "bun build src/client.tsx --outdir dist/static/ --watch",
    "build:client": "bun build src/client.tsx --outdir dist/static/ --minify",
    "dev:css": "tailwindcss -i src/style.css -o dist/static/style.css --watch",
    "build:css": "tailwindcss -i src/style.css -o dist/static/style.css --minify"
  },
  "dependencies": {
    "@date-fns/tz": "^1.4.1",
    "@googleapis/calendar": "^14.2.0",
    "date-fns": "^4.1.0",
    "google-auth-library": "^10.5.0",
    "hono": "^4.11.9",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.1.18",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/cli": "^4.2.1",
    "@types/bun": "latest",
    "concurrently": "^9.2.1",
    "oxfmt": "^0.33.0",
    "oxlint": "^1.48.0",
    "typescript": "^5.9.3"
  }
}
